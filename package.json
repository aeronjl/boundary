{
	"name": "boundary",
	"version": "0.0.1",
	"private": true,
	"packageManager": "bun@1.3.13",
	"scripts": {
		"dev": "bun run db:setup && bun --bun vite dev",
		"build": "bun --bun vite build && bun run scripts/vercel-include-ws.ts",
		"preview": "bun --bun vite preview",
		"test": "bun run test:integration && bun run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:integration": "playwright test",
		"test:unit": "vitest",
		"ci": "bun run check && bun run lint && bun run test && bun run build",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun run scripts/db-migrate.ts",
		"db:seed": "bun run scripts/db-seed.ts",
		"db:setup": "bun run db:migrate && bun run db:seed",
		"db:deploy": "bun run db:migrate && bun run db:seed",
		"db:studio": "drizzle-kit studio",
		"reference:import": "bun run scripts/reference-import.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.4",
		"@types/bun": "^1.3.13",
		"@types/eslint": "^9.6.1",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vercel": "^52.0.0",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"type": "module",
	"dependencies": {
		"@libsql/client": "^0.17.3",
		"@threlte/core": "^8.5.9",
		"drizzle-orm": "^0.45.2",
		"layercake": "^10.0.2",
		"three": "^0.184.0",
		"ws": "^8.20.0"
	},
	"overrides": {
		"cookie": "0.7.2",
		"esbuild": "0.28.0",
		"flatted": "3.4.2",
		"prismjs": "1.30.0",
		"yaml": "2.8.3"
	}
}
